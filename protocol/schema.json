{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://touch.dev/protocol/schema.json",
  "title": "TouchProtocol",
  "description": "Single source of truth for the Touch editor<->engine WebSocket protocol (ADR-0005). Domain types + control-message envelopes + the mesh binary-frame envelope. TS + pydantic bindings are generated from this file (`make codegen`).",
  "type": "object",
  "$defs": {
    "OperationKind": {
      "title": "OperationKind",
      "description": "The 11 v0 operation kinds (6 primary + 5 modifier, carried from Maquette).",
      "type": "string",
      "enum": [
        "box", "cylinder", "sphere", "extrude", "revolve", "loft",
        "hole", "fillet", "chamfer", "shell", "pattern"
      ]
    },
    "Axis": {
      "title": "Axis",
      "type": "string",
      "enum": ["+X", "-X", "+Y", "-Y", "+Z", "-Z"]
    },
    "SurfaceType": {
      "title": "SurfaceType",
      "type": "string",
      "enum": ["planar", "cylindrical", "spherical", "conical", "toroidal", "freeform"]
    },
    "Point3": {
      "title": "Point3",
      "description": "World-space point [x, y, z] in mm.",
      "type": "array",
      "items": {"type": "number"},
      "minItems": 3,
      "maxItems": 3
    },
    "Parameter": {
      "title": "Parameter",
      "description": "A named dimensioned scalar (carried from Maquette; referenceable in extras).",
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "value": {"type": "number"},
        "unit": {"type": "string", "enum": ["mm", "cm", "m", "in"]}
      },
      "required": ["name", "value", "unit"],
      "additionalProperties": false
    },
    "ConversationTurn": {
      "title": "ConversationTurn",
      "description": "A single exchange in a clarification thread.",
      "type": "object",
      "properties": {
        "from": {"type": "string", "enum": ["user", "assistant"]},
        "text": {"type": "string"},
        "at": {"type": "string", "format": "date-time"}
      },
      "required": ["from", "text", "at"],
      "additionalProperties": false
    },
    "FinderPredicate": {
      "title": "FinderPredicate",
      "description": "A re-derivable geometric predicate identifying a face/edge/vertex across replay (ADR-0008). ANDed within a Selection.",
      "oneOf": [
        {
          "title": "PlaneNormalPredicate",
          "type": "object",
          "properties": {
            "kind": {"const": "plane_normal"},
            "axis": {"$ref": "#/$defs/Axis"}
          },
          "required": ["kind", "axis"],
          "additionalProperties": false
        },
        {
          "title": "ContainsPointPredicate",
          "type": "object",
          "properties": {
            "kind": {"const": "contains_point"},
            "point_xyz": {"$ref": "#/$defs/Point3"},
            "tol_mm": {"type": "number"}
          },
          "required": ["kind", "point_xyz", "tol_mm"],
          "additionalProperties": false
        },
        {
          "title": "SurfaceTypePredicate",
          "type": "object",
          "properties": {
            "kind": {"const": "surface_type"},
            "value": {"$ref": "#/$defs/SurfaceType"}
          },
          "required": ["kind", "value"],
          "additionalProperties": false
        },
        {
          "title": "CentroidNearPredicate",
          "type": "object",
          "properties": {
            "kind": {"const": "centroid_near"},
            "point_xyz": {"$ref": "#/$defs/Point3"},
            "tol_mm": {"type": "number"}
          },
          "required": ["kind", "point_xyz", "tol_mm"],
          "additionalProperties": false
        },
        {
          "title": "OfFeaturePredicate",
          "type": "object",
          "properties": {
            "kind": {"const": "of_feature"},
            "op_id": {"type": "string"}
          },
          "required": ["kind", "op_id"],
          "additionalProperties": false
        },
        {
          "title": "AreaNearPredicate",
          "type": "object",
          "properties": {
            "kind": {"const": "area_near"},
            "area_mm2": {"type": "number"},
            "tol": {"type": "number"}
          },
          "required": ["kind", "area_mm2", "tol"],
          "additionalProperties": false
        },
        {
          "title": "EdgesCountPredicate",
          "type": "object",
          "properties": {
            "kind": {"const": "edges_count"},
            "count": {"type": "integer"}
          },
          "required": ["kind", "count"],
          "additionalProperties": false
        }
      ]
    },
    "Selection": {
      "title": "Selection",
      "description": "Identifies a face/edge/vertex such that identity survives history replay (ADR-0008).",
      "type": "object",
      "properties": {
        "target": {"type": "string", "enum": ["face", "edge", "vertex"]},
        "point_xyz": {"$ref": "#/$defs/Point3"},
        "finder": {
          "type": "array",
          "items": {"$ref": "#/$defs/FinderPredicate"},
          "minItems": 1
        },
        "face_id_at_capture": {"type": ["integer", "null"]}
      },
      "required": ["target", "point_xyz", "finder"],
      "additionalProperties": false
    },
    "Operation": {
      "title": "Operation",
      "description": "A single user-driven CAD action appended to the document history.",
      "type": "object",
      "properties": {
        "id": {"type": "string", "description": "UUID, stable across sessions."},
        "kind": {"$ref": "#/$defs/OperationKind"},
        "params": {
          "type": "object",
          "additionalProperties": {"type": ["number", "string", "boolean"]}
        },
        "selection": {
          "oneOf": [{"$ref": "#/$defs/Selection"}, {"type": "null"}]
        },
        "prompt_text": {"type": "string"},
        "conversation": {
          "type": "array",
          "items": {"$ref": "#/$defs/ConversationTurn"}
        },
        "created_at": {"type": "string", "format": "date-time"}
      },
      "required": ["id", "kind", "params", "prompt_text", "conversation", "created_at"],
      "additionalProperties": false
    },
    "ClarifyingQuestion": {
      "title": "ClarifyingQuestion",
      "description": "The planner's request for disambiguation (F7) when a prompt is ambiguous.",
      "type": "object",
      "properties": {
        "question": {"type": "string"},
        "attempt": {"type": "integer"}
      },
      "required": ["question", "attempt"],
      "additionalProperties": false
    },
    "MsgPlan": {
      "title": "MsgPlan",
      "description": "FE->BE: submit a prompt (+ optional selection context) for planning.",
      "type": "object",
      "properties": {
        "type": {"const": "plan"},
        "prompt_text": {"type": "string"},
        "selection": {
          "oneOf": [{"$ref": "#/$defs/Selection"}, {"type": "null"}]
        }
      },
      "required": ["type", "prompt_text"],
      "additionalProperties": false
    },
    "MsgApplyOp": {
      "title": "MsgApplyOp",
      "description": "FE->BE: apply a structured operation directly (no planning).",
      "type": "object",
      "properties": {
        "type": {"const": "applyOp"},
        "operation": {"$ref": "#/$defs/Operation"}
      },
      "required": ["type", "operation"],
      "additionalProperties": false
    },
    "MsgCancel": {
      "title": "MsgCancel",
      "description": "FE->BE: cancel the in-flight LLM/executor work (F17).",
      "type": "object",
      "properties": {"type": {"const": "cancel"}},
      "required": ["type"],
      "additionalProperties": false
    },
    "MsgRebuild": {
      "title": "MsgRebuild",
      "description": "FE->BE: replay the document history and re-stream the mesh.",
      "type": "object",
      "properties": {"type": {"const": "rebuild"}},
      "required": ["type"],
      "additionalProperties": false
    },
    "MsgExportStep": {
      "title": "MsgExportStep",
      "description": "FE->BE: export the current solid to a STEP file.",
      "type": "object",
      "properties": {
        "type": {"const": "exportStep"},
        "path": {"type": ["string", "null"]}
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "MsgReady": {
      "title": "MsgReady",
      "description": "BE->FE: backend is up and accepting messages (F15).",
      "type": "object",
      "properties": {
        "type": {"const": "ready"},
        "schema_version": {"type": "integer"}
      },
      "required": ["type", "schema_version"],
      "additionalProperties": false
    },
    "MsgProgress": {
      "title": "MsgProgress",
      "description": "BE->FE: progress update for a long-running operation.",
      "type": "object",
      "properties": {
        "type": {"const": "progress"},
        "stage": {"type": "string"},
        "message": {"type": ["string", "null"]}
      },
      "required": ["type", "stage"],
      "additionalProperties": false
    },
    "MsgOp": {
      "title": "MsgOp",
      "description": "BE->FE: the structured operation the planner produced and applied.",
      "type": "object",
      "properties": {
        "type": {"const": "op"},
        "operation": {"$ref": "#/$defs/Operation"}
      },
      "required": ["type", "operation"],
      "additionalProperties": false
    },
    "MsgConversationTurn": {
      "title": "MsgConversationTurn",
      "description": "Either direction: a clarification turn (assistant question or user reply, F7).",
      "type": "object",
      "properties": {
        "type": {"const": "conversationTurn"},
        "turn": {"$ref": "#/$defs/ConversationTurn"},
        "question": {
          "oneOf": [{"$ref": "#/$defs/ClarifyingQuestion"}, {"type": "null"}]
        }
      },
      "required": ["type", "turn"],
      "additionalProperties": false
    },
    "MsgError": {
      "title": "MsgError",
      "description": "BE->FE: a structured error (F21). Never a raw Python traceback.",
      "type": "object",
      "properties": {
        "type": {"const": "error"},
        "code": {"type": "string"},
        "message": {"type": "string"},
        "where": {"type": ["string", "null"]}
      },
      "required": ["type", "code", "message"],
      "additionalProperties": false
    },
    "MsgMeshFrame": {
      "title": "MsgMeshFrame",
      "description": "BE->FE: the JSON envelope that immediately precedes a binary mesh frame (F20). The binary buffers (vertices/normals/indices/face_tag_per_triangle/edge_tag_per_segment) follow as the next WS binary message.",
      "type": "object",
      "properties": {
        "type": {"const": "meshFrame"},
        "version": {"type": "integer"},
        "vertex_count": {"type": "integer"},
        "triangle_count": {"type": "integer"},
        "edge_segment_count": {"type": "integer"},
        "face_id_to_finder_hint": {
          "type": "object",
          "description": "Map of (stringified u32 face id) -> Selection, for the FE click->selection flow.",
          "additionalProperties": {"$ref": "#/$defs/Selection"}
        }
      },
      "required": ["type", "version", "vertex_count", "triangle_count", "edge_segment_count", "face_id_to_finder_hint"],
      "additionalProperties": false
    },
    "Message": {
      "title": "Message",
      "description": "Any control-message envelope on the wire (discriminated by `type`).",
      "oneOf": [
        {"$ref": "#/$defs/MsgPlan"},
        {"$ref": "#/$defs/MsgApplyOp"},
        {"$ref": "#/$defs/MsgCancel"},
        {"$ref": "#/$defs/MsgRebuild"},
        {"$ref": "#/$defs/MsgExportStep"},
        {"$ref": "#/$defs/MsgReady"},
        {"$ref": "#/$defs/MsgProgress"},
        {"$ref": "#/$defs/MsgOp"},
        {"$ref": "#/$defs/MsgConversationTurn"},
        {"$ref": "#/$defs/MsgError"},
        {"$ref": "#/$defs/MsgMeshFrame"}
      ]
    }
  },
  "properties": {
    "message": {"$ref": "#/$defs/Message"}
  },
  "additionalProperties": false
}
