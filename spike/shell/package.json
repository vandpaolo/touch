{
  "name": "touch-shell-spike",
  "private": true,
  "version": "0.1.0",
  "description": "T0 packaging-spike Electron shell — throwaway. Spawns the Python sidecar, waits for TOUCH_READY, opens the viewport with ?port injected, and supervises the sidecar lifecycle.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && electron .",
    "smoke": "npm run build && node dist/smoke.js",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "electron": "^38.2.2",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.2"
  },
  "build": {
    "appId": "dev.touch.spike",
    "productName": "Touch-spike",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web"
      },
      {
        "from": "../sidecar/dist/touch_sidecar",
        "to": "sidecar"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Touch-spike-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
